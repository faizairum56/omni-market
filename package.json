{
  "name": "omni-market",
  "version": "4.0.0",
  "description": "Omni-Market — 23 GoF Patterns + SQLite + REST API + React UI",
  "main": "src/index.js",
  "scripts": {
    "start":      "node src/server.js",
    "dev:server": "node src/server.js",
    "dev:client": "cd client && npm run dev",
    "build":      "cd client && npm run build",
    "demo":       "node src/index.js",
    "seed":       "node src/db/seed.js",
    "clean":      "node -e \"require('fs').rmSync('omni-market.db',{force:true})\""
  },
  "dependencies": {
    "bcryptjs":     "^2.4.3",
    "cors":         "^2.8.5",
    "dotenv":       "^16.4.5",
    "express":      "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer":   "^6.9.13",
    "sql.js":       "^1.14.1",
    "stripe":       "^15.12.0"
  }
}